{
  "$schema": "https://raw.githubusercontent.com/nicedayzhu/tauri-v2-schema/main/tauri.conf.json",
  "productName": "ClawSec Monitor",
  "version": "3.0.0",
  "identifier": "com.clawsec.monitor",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "cd ../frontend && pnpm dev",
    "beforeBuildCommand": "cd ../frontend && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "ClawSec Monitor",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  }
}
